# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
.ty_cache/

# mise
# (mise.lock IS committed — reproducible tool installs)

# graphify outputs — large/regenerable; rebuilt from committed sources.
# Keep the shareable wiki if one is generated.
graphify-out/
!graphify-out/wiki/

# graphify per-install state (generated by `graphify install`/runs; not source)
.claude/skills/graphify/.graphify_version
.claude/skills/**/.graphify_root

# Vendored external corpora — cloned at build time from sources/*.manifest,
# NOT committed (reproducible-by-reference; keeps the repo light).
sources/*/
!sources/.gitkeep

# OS / editor
.DS_Store
