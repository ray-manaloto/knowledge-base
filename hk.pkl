amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"

// Builtin linters MUST be assigned from Builtins (`= Builtins.name`), never a
// bare `["name"] {}` block — a bare block is a fresh empty Step that hk silently
// skips. See ray-manaloto/dotfiles feedback_hk_builtins_need_assignment.
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

// Refuse this config on an older hk binary rather than silently misreading it.
min_hk_version = "1.49.0"

// Zero-skip: report ALL issues, not just the first.
fail_fast = false

// Non-source paths excluded from every builtin.
exclude = List(
  "graphify-out/**",
  "sources/**",
  "**/.venv/**",
  "**/__pycache__/**",
  "**/*.lock",
)

// Python: ruff (strict `select=ALL`; config in python/pyproject.toml) + ty
// (strict static type check). The `uv run --project python` prefix makes hk use
// the repo's pinned ruff/ty and its config verbatim. Order per Astral docs:
// `ruff check --fix` BEFORE `ruff format`; `exclusive` (a barrier), NOT `depends`
// — a failed `depends` dep deadlocks hk (dotfiles #268). ty is a cross-module
// analyzer, so it runs whole-dir (not file-scoped) with --project to attach the
// [tool.ty] config. Builtins are amended (`= (Builtins.x) {}`), never bare blocks
// (feedback_hk_builtins_need_assignment); `ty` is a custom step, so a bare block.
hooks {
  ["check"] {
    steps {
      ["typos"] = Builtins.typos
      ["pkl"] = Builtins.pkl
      ["ruff"] = (Builtins.ruff) { prefix = "uv run --project python" }
      ["ruff_format"] = (Builtins.ruff_format) {
        prefix = "uv run --project python"
        exclusive = true
      }
      ["ty"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run --project python ty check --project python python/src tests"
      }
    }
  }
  ["fix"] {
    fix = true
    steps {
      ["typos"] = Builtins.typos
      ["pkl"] = Builtins.pkl
      ["ruff"] = (Builtins.ruff) { prefix = "uv run --project python" }
      ["ruff_format"] = (Builtins.ruff_format) {
        prefix = "uv run --project python"
        exclusive = true
      }
      ["ty"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run --project python ty check --project python python/src tests"
      }
    }
  }
  ["pre-commit"] {
    fix = true
    steps {
      ["typos"] = Builtins.typos
      ["pkl"] = Builtins.pkl
      ["ruff"] = (Builtins.ruff) { prefix = "uv run --project python" }
      ["ruff_format"] = (Builtins.ruff_format) {
        prefix = "uv run --project python"
        exclusive = true
      }
      ["ty"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run --project python ty check --project python python/src tests"
      }
    }
  }
}
