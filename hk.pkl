amends "package://github.com/jdx/hk/releases/download/v1.52.0/hk@1.52.0#/Config.pkl"

// Builtin linters MUST be assigned from Builtins (`= Builtins.name`), never a
// bare `["name"] {}` block — a bare block is a fresh empty Step that hk silently
// skips. See ray-manaloto/dotfiles feedback_hk_builtins_need_assignment.
import "package://github.com/jdx/hk/releases/download/v1.52.0/hk@1.52.0#/Builtins.pkl"

// Refuse this config on an older hk binary rather than silently misreading it.
min_hk_version = "1.49.0"

// Zero-skip: report ALL issues, not just the first.
fail_fast = false

// Non-source paths excluded from every builtin.
exclude = List(
  "graphify-out/**",
  "sources/**",
  "**/.venv/**",
  "**/__pycache__/**",
  "**/*.lock",
)

// Python: ruff (strict `select=ALL`) + ty (strict types); config in the single
// repo-root pyproject.toml, so `uv run` (no --project) uses it for BOTH python/src
// and tests/. ruff/ruff_format/ty are all CUSTOM shell-string steps: hk 1.51+
// (#1067) moved the ruff builtins to structured `argv` commands, which "can't be
// combined with `shell` or `prefix`" — so `(Builtins.ruff){prefix=…}` panics.
// A string `check`/`fix` carries the `uv run` prefix instead. Order per Astral
// docs: `ruff check --fix` BEFORE `ruff format`; `exclusive` (a barrier), NOT
// `depends` — a failed `depends` dep deadlocks hk (dotfiles #268). ty is a
// cross-module analyzer, so it runs whole-dir (python/src tests), not file-scoped.
hooks {
  ["check"] {
    steps {
      ["typos"] = Builtins.typos
      ["pkl"] = Builtins.pkl
      ["ruff"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ruff check {{files}}"
        fix = "uv run ruff check --fix {{files}}"
      }
      ["ruff_format"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ruff format --check {{files}}"
        fix = "uv run ruff format {{files}}"
        exclusive = true
      }
      ["ty"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ty check python/src tests"
      }
    }
  }
  ["fix"] {
    fix = true
    steps {
      ["typos"] = Builtins.typos
      ["pkl"] = Builtins.pkl
      ["ruff"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ruff check {{files}}"
        fix = "uv run ruff check --fix {{files}}"
      }
      ["ruff_format"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ruff format --check {{files}}"
        fix = "uv run ruff format {{files}}"
        exclusive = true
      }
      ["ty"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ty check python/src tests"
      }
    }
  }
  ["pre-commit"] {
    fix = true
    steps {
      ["typos"] = Builtins.typos
      ["pkl"] = Builtins.pkl
      ["ruff"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ruff check {{files}}"
        fix = "uv run ruff check --fix {{files}}"
      }
      ["ruff_format"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ruff format --check {{files}}"
        fix = "uv run ruff format {{files}}"
        exclusive = true
      }
      ["ty"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run ty check python/src tests"
      }
    }
  }
}
